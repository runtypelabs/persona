# Copy this file to .env and fill in your actual values
# .env is gitignored and used for local development

# Required: Runtype API key the proxy uses to authenticate upstream dispatch.
RUNTYPE_API_KEY=rt_your_api_key_here

# Optional: Port for the server (defaults to 43111)
# PORT=43111

# Portable per-process/isolate abuse controls for the public demo.
# PROXY_RATE_LIMIT_REQUESTS=60
# PROXY_EXPENSIVE_RATE_LIMIT_REQUESTS=20
# PROXY_RATE_LIMIT_WINDOW_SECONDS=60
# Chat JSON defaults to 16 MiB and is clamped to 16-64 MiB for attachments.
# PROXY_MAX_BODY_BYTES=16777216
# Optional for private/server-to-server deployments only. Never expose this in frontend JS.
# PROXY_BEARER_TOKEN=replace_with_a_long_random_token

# Optional: upstream dispatch endpoint (defaults to https://api.runtype.com/v1/dispatch).
# UPSTREAM_URL=https://api.runtype-staging.com/v1/dispatch

# Optional: pin single-agent demo routes to existing hosted Runtype agent ids
# instead of their bundled server-pinned AgentConfig definitions.
# AGENT_ID_WEBMCP=agent_your_webmcp_storefront_agent_id_here
# AGENT_ID_PAGE_CONTEXT=agent_your_page_context_agent_id_here
# AGENT_ID_THEME_ASSISTANT=agent_your_theme_assistant_agent_id_here
# AGENT_ID_ANALYTICS=agent_your_analytics_agent_id_here

# Optional compatibility fallback: pin the Theme Copilot to an existing Runtype
# flow id instead of the bundled THEME_ASSISTANT_AGENT config. The model must
# emit native tool calls and accept image input (reference images +
# screenshot_preview results).
# FLOW_ID_THEME_ASSISTANT=flow_your_theme_assistant_flow_id_here

# Optional: Flow IDs for specific chat endpoints
# If set, these will be used instead of the hardcoded flow configurations
# FLOW_ID_FORM_DIRECTIVE=flow_your_form_directive_flow_id_here
# FLOW_ID_SHOPPING_ASSISTANT=flow_your_shopping_assistant_flow_id_here
# FLOW_ID_SHOPPING_ASSISTANT_METADATA=flow_your_shopping_metadata_flow_id_here

# Optional: Stripe secret key for checkout functionality
# Required for /api/checkout endpoint and shopping assistant checkout actions
# STRIPE_SECRET_KEY=sk_test_your_stripe_key_here
# Organization keys (sk_org_…) also need the Stripe account to bill (see Dashboard → account ID)
# STRIPE_CONTEXT=acct_xxxxxxxxxxxxx

# Optional: Frontend URL for checkout success/cancel redirects
# FRONTEND_URL=http://localhost:5173

# Optional: OpenAI key for the streaming text-to-speech demo (/api/tts).
# Required for the "Server TTS (streaming)" example page; the key stays on the
# proxy and only PCM audio is streamed to the browser.
# OPENAI_API_KEY=sk-your_openai_api_key_here
# OPENAI_TTS_MODEL=tts-1   # low-latency default; gpt-4o-mini-tts = higher quality but slower/burstier start
# OPENAI_TTS_VOICE=alloy   # alloy | echo | fable | onyx | nova | shimmer
