# This example runs with NO configuration. The default agent is a
# zero-dependency echo. Everything below is optional.

# Port for this example's server (defaults to 3110).
PORT=3110

# Optional: stream a real model instead of the echo. Set this key and switch the
# handler in src/index.ts to `openAiResponder(process.env.OPENAI_API_KEY!)`.
OPENAI_API_KEY=
