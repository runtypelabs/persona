# eve runs its own dev server (filesystem-first agent) on 127.0.0.1:3000 by
# default. Start it separately (`npx eve@latest dev`) and point this example at
# it. eve needs Node >= 24. This example's own dev server runs on :3100 to avoid
# colliding with eve's :3000.
EVE_HOST=http://127.0.0.1:3000

# eve resolves the model via the Vercel AI Gateway by default.
# See https://github.com/vercel/eve
AI_GATEWAY_API_KEY=
