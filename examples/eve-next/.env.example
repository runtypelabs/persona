# eve auto-starts with `next dev` via withEve() in next.config.mjs (Node >= 24),
# so there's no separate server to run. It resolves the model through the Vercel
# AI Gateway, so set a key to get real responses:
AI_GATEWAY_API_KEY=

# Optional: point the dispatch route at an already-running eve server instead of
# the one withEve() launches. Leave unset for the default same-origin setup.
# EVE_BASE_URL=http://127.0.0.1:3000
