# Proxy mode (default) — used by most demos
# The proxy server holds the API key and forwards requests to Runtype.
VITE_PROXY_PORT=43111
# VITE_PROXY_URL=http://localhost:43111

# Client token mode — used by feedback-integration-demo, client-token-demo, action-middleware (when set).
# Create a client token via the Runtype dashboard or POST /v1/client-tokens.
# Client tokens are browser-safe (origin-locked, rate-limited, session-scoped).
# Page context is sent as /v1/client/chat `inputs` (root template vars: {{page_url}}, {{page_elements}}, …).
# Update your Runtype agent system prompt from {{_record.metadata.page_*}} to {{page_*}} when using inputs-only.
# VITE_CLIENT_TOKEN=ct_live_...

# Override the Runtype API base URL (client token mode only).
# Defaults to https://api.runtype.com when not set.
# VITE_API_URL=http://localhost:8787
