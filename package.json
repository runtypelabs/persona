{
  "name": "persona",
  "private": true,
  "scripts": {
    "build": "pnpm --filter @runtypelabs/persona build && pnpm --filter @runtypelabs/persona-proxy build",
    "build:widget": "pnpm --filter @runtypelabs/persona build",
    "build:proxy": "pnpm --filter @runtypelabs/persona-proxy build",
    "lint": "pnpm --filter @runtypelabs/persona lint && pnpm --filter @runtypelabs/persona-proxy lint",
    "typecheck": "pnpm --filter @runtypelabs/persona typecheck && pnpm --filter @runtypelabs/persona-proxy typecheck",
    "dev:widget": "pnpm --filter web dev",
    "dev:runtype-hono-proxy": "pnpm --filter runtype-hono-proxy dev",
    "dev:runtype-workers": "pnpm --filter runtype-hono-proxy dev:workers",
    "dev": "pnpm --filter @runtypelabs/persona build:styles && NODE_ENV=development concurrently \"pnpm dev:runtype-hono-proxy\" \"pnpm dev:widget\"",
    "changeset": "changeset",
    "release": "changeset publish",
    "fetch:runtype-openapi": "pnpm --filter @runtypelabs/persona fetch:runtype-openapi",
    "generate:runtype-types": "pnpm --filter @runtypelabs/persona generate:runtype-types",
    "check:runtype-types": "pnpm --filter @runtypelabs/persona check:runtype-types"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "concurrently": "^8.2.2"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b"
}
